//@version=6
// =============================================================================
// TFC Entry + BF Exit [TVB-14] -- tier-1 live watch surface, v4.
// ORDER-FREE indicator: paints entries/exits and fires alerts; never trades.
//
// WHAT CHANGED IN v4 (designed with the user 2026-07-19, pre new-weekly-open):
//   - BF detection is now the ROLLING COMPOUND-3 POOL on ONE base timeframe
//     (default W), replacing the four fixed calendar rungs. The rule, the
//     user's own sentence mechanized: at each base-TF close, the envelope
//     (highest high / lowest low) of the last N closed candles strictly takes
//     out BOTH sides of the envelope of the N candles before them. N=1 is the
//     ordinary scenario 3; N>1 is the compound 3. No calendars, so
//     month-straddling "atypical timeframe" structures are found natively.
//   - Wick-time anchors (user-ratified): each line connects the taken-out
//     extreme to the extreme that took it out, at the times those wicks
//     printed. This is the only convention where a line survives switching
//     chart timeframes unchanged (the MU Feb->Mar lesson).
//   - DIRECTION-RELATIVE exits: a short exits only at a line BELOW its entry
//     (long: above). A line on the wrong side is retest-rejection context and
//     NEVER an exit (the day-one overhead-line lesson, now structural).
//   - Lifecycle: alive -> consumed (containment touch; faded reclaim level)
//     or crossed (confirmed close beyond; faded) or superseded (same
//     structure re-anchored). Retired lines stay drawn faded (toggle) --
//     the TTO ladder back-walk emerges naturally: next alive line down IS
//     the next harvest rung.
//
// QUICK START
//   1. Add to a 24/7 perp chart (5m/15m fine; chart TF must tile the base TF).
//   2. ENTRY (unchanged from v3): full D/W/M alignment (close vs each period
//      open) + strict break of the prior COMPLETED arm-TF bar extreme
//      (+/- 1 tick), intrabar, corrected clock.
//   3. EXIT: first bar whose range CONTAINS an alive BF line on the profit
//      side of the position (short: line below entry; long: above). Labels:
//      "BF S Exit" / "BF L Exit" (+ "Flip S/L Exit" backstop).
//   4. Lines: solid = alive; faded dashed = retired (consumed/crossed/
//      superseded). New formations appear on the FIRST bar after a base-TF
//      close -- watch the redraw live at 00:00 UTC Monday on W.
//   5. Alerts: Enter Long / Enter Short / Exit Long / Exit Short / Any.
//      Use "Once per bar".
//
// HONEST DELTAS (v4):
//   - ONE base timeframe per instance (default W). The multi-TF fractal grid
//     is future work; add a second instance on another base TF meanwhile.
//   - Chart-side aggregation: exact when the chart TF tiles the base TF on
//     24/7 perps (5m/15m -> W: yes). No request.security anywhere.
//   - The pool needs chart history back to the structures you care about;
//     on short-history charts the earliest formations may be missed.
//   - Detection at base-TF closes only (closed candles, Rob-canonical);
//     touches/exits evaluate intrabar continuously. Signals/marks only; no
//     fees/funding/slippage modeled.
//   - DRAM weekly acceptance fixture (venue bars, 2026-07-19): F1 born
//     Jun-8 N=1 lower 55.000@May-26 -> 52.788@Jun-6 (alive, 44.02 at
//     Jul-20); F2 born Jun-29 N=1 lower 67.417@Jun-15 -> 67.184@Jun-24
//     (consumed Jun-29 14:00); F3 births at the Jul-20 00:00 UTC roll,
//     N=4, lower 52.788@Jun-6 -> 48.663@Jul-17 (48.42 at Jul-20), upper
//     duplicates F2's upper (per-side dup guard keeps one line).
// =============================================================================
indicator('TFC Entry + BF Exit [TVB-14]', 'TFC-BF', overlay = true, max_lines_count = 100, max_labels_count = 500)

// ------------------------------- inputs --------------------------------------
grp_g = 'Entry gate'
g1 = input.timeframe('D', 'Gate TF 1', group = grp_g, tooltip = 'Continuity gate: close vs this timeframe period open. Full alignment of all three gates in a direction permits entries that way.')
g2 = input.timeframe('W', 'Gate TF 2', group = grp_g)
g3 = input.timeframe('M', 'Gate TF 3', group = grp_g)
arm_tf = input.timeframe('15', 'Arm TF (trigger = prior completed bar extreme)', group = grp_g, tooltip = 'Entry trigger = strict break of the PRIOR COMPLETED bar of this timeframe, +/- 1 tick. Corrected clock: tested before the snapshot rolls.')
allow_long = input.bool(true, 'Long entries', group = grp_g, inline = 'd')
allow_short = input.bool(true, 'Short entries', group = grp_g, inline = 'd')

grp_x = 'BF exit (rolling compound-3 pool)'
tf_base = input.timeframe('W', 'Base timeframe', group = grp_x, tooltip = 'Formations are detected on CLOSED candles of this timeframe. The rolling rule: last N candles envelope strictly outside the prior N candles envelope. Start weekly (less noisy); one base TF per instance.')
n_max = input.int(6, 'Max series length N', minval = 1, maxval = 13, group = grp_x, tooltip = 'Largest window tried by the rolling scan. N=1 is a plain scenario 3; N=4 found the DRAM Jun-22..Jul-13 compound. Bounded by available history (needs 2N closed candles).')
pool_cap = input.int(12, 'Max formations kept', minval = 3, maxval = 30, group = grp_x, tooltip = 'Oldest formations (and their lines) are dropped beyond this. Keeps charts and memory clean.')
flip_backstop = input.bool(true, 'Flip backstop exit', group = grp_x, tooltip = 'If no BF line is reached, exit on full OPPOSITE gate alignment at a confirmed bar close. The no-line fallback.')
warn_pct = input.float(0.5, 'Heads-up distance (%)', minval = 0.0, step = 0.1, group = grp_x, tooltip = 'Paint a warning char when price is within this percent of the next harvest line. 0 disables.')

grp_v = 'Display'
show_lines = input.bool(true, 'Show BF lines', group = grp_v, tooltip = 'The lines themselves. Toggle off for a signals-only chart (entries/exits still fire).')
show_retired = input.bool(true, 'Show retired lines (faded)', group = grp_v, tooltip = 'Consumed/crossed/superseded lines kept as faded dashed reclaim levels. Toggle off to declutter (phone mode).')
show_bg = input.bool(true, 'Tint background while in position', group = grp_v)
show_table = input.bool(true, 'Status table', group = grp_v)
c_long = input.color(color.new(#26a69a, 0), 'Long', group = grp_v, inline = 'c')
c_short = input.color(color.new(#ef5350, 0), 'Short', group = grp_v, inline = 'c')
c_line = input.color(color.new(#ffb74d, 0), 'BF line', group = grp_v, inline = 'c')

// ------------------------------- gates ---------------------------------------
f_open(simple string tf) =>
    ta.valuewhen(timeframe.change(tf), open, 0)

oA = f_open(g1)
oB = f_open(g2)
oC = f_open(g3)
bool gate_ready = not na(oA) and not na(oB) and not na(oC)
bool gate_up = gate_ready and close > oA and close > oB and close > oC
bool gate_dn = gate_ready and close < oA and close < oB and close < oC

// ------------------- arm snapshot (corrected clock) --------------------------
bool arm_new = timeframe.change(arm_tf)
bool arm_last = time_close == time_close(arm_tf)
var float a_hi = na
var float a_lo = na
var float prev_ah = na
var float prev_al = na
if arm_new
    a_hi := high
    a_lo := low
else
    a_hi := na(a_hi) ? high : math.max(a_hi, high)
    a_lo := na(a_lo) ? low : math.min(a_lo, low)
// NOTE: prev_ah/prev_al are tested by the entry logic below and only rolled at
// the very end of the script -- rollback then guarantees the completed-period
// reference on every child bar, including chart TF == arm TF (audit C1 fix).

// --------------- base-TF accumulation (closed-candle history) ----------------
// Envelope history of CLOSED base-TF candles, with wick times. Chart-side
// aggregation, zero request.security. Capped at 2*n_max (sweep lookback).
var array<float> bH = array.new<float>()
var array<float> bL = array.new<float>()
var array<int> bHT = array.new<int>()
var array<int> bLT = array.new<int>()
var float cur_hi = na
var float cur_lo = na
var int cur_hiT = na
var int cur_loT = na

// ------------------------------ formation pool -------------------------------
// Parallel arrays; states: 0 alive, 1 consumed (touch), 2 crossed (confirmed
// close beyond), 3 superseded (same structure re-anchored), 4 ghost (side
// duplicated an existing line -- never drawn, never active).
var array<int> p_N = array.new<int>()
var array<int> p_born = array.new<int>()
var array<int> p_lo_t1 = array.new<int>()
var array<float> p_lo_v1 = array.new<float>()
var array<int> p_lo_t2 = array.new<int>()
var array<float> p_lo_v2 = array.new<float>()
var array<int> p_lo_st = array.new<int>()
var array<line> p_lo_ln = array.new<line>()
var array<int> p_up_t1 = array.new<int>()
var array<float> p_up_v1 = array.new<float>()
var array<int> p_up_t2 = array.new<int>()
var array<float> p_up_v2 = array.new<float>()
var array<int> p_up_st = array.new<int>()
var array<line> p_up_ln = array.new<line>()

f_val(int t1, float v1, int t2, float v2) =>
    t2 == t1 ? v2 : v2 + (v2 - v1) / (t2 - t1) * (time - t2)

f_lo_val(int i) =>
    f_val(array.get(p_lo_t1, i), array.get(p_lo_v1, i), array.get(p_lo_t2, i), array.get(p_lo_v2, i))

f_up_val(int i) =>
    f_val(array.get(p_up_t1, i), array.get(p_up_v1, i), array.get(p_up_t2, i), array.get(p_up_v2, i))

f_retire(line ln) =>
    if not na(ln)
        if show_retired
            line.set_color(ln, color.new(c_line, 72))
            line.set_style(ln, line.style_dashed)
            line.set_width(ln, 1)
        else
            line.delete(ln)

f_draw(int t1, float v1, int t2, float v2) =>
    show_lines ? line.new(t1, v1, t2, v2, xloc = xloc.bar_time, extend = extend.right, color = c_line, width = 2) : line(na)

// ---------------- detection at base-TF close (the rolling sweep) -------------
bool base_roll = timeframe.change(tf_base)
if base_roll and not na(cur_hi)
    // the accumulating candle just COMPLETED: push it, then sweep (closed data only)
    array.push(bH, cur_hi)
    array.push(bL, cur_lo)
    array.push(bHT, cur_hiT)
    array.push(bLT, cur_loT)
    if array.size(bH) > 2 * n_max
        array.shift(bH)
        array.shift(bL)
        array.shift(bHT)
        array.shift(bLT)
    int cnt = array.size(bH)
    bool found = false
    for n = 1 to n_max
        if not found and cnt >= 2 * n
            float aHm = -1.0e18
            float aLm = 1.0e18
            int aHt = 0
            int aLt = 0
            float bHm = -1.0e18
            float bLm = 1.0e18
            int bHt = 0
            int bLt = 0
            for j = cnt - n to cnt - 1
                if array.get(bH, j) > aHm
                    aHm := array.get(bH, j)
                    aHt := array.get(bHT, j)
                if array.get(bL, j) < aLm
                    aLm := array.get(bL, j)
                    aLt := array.get(bLT, j)
            for j = cnt - 2 * n to cnt - n - 1
                if array.get(bH, j) > bHm
                    bHm := array.get(bH, j)
                    bHt := array.get(bHT, j)
                if array.get(bL, j) < bLm
                    bLm := array.get(bL, j)
                    bLt := array.get(bLT, j)
            // strict both-sides takeout (R10 operators; equality never breaks)
            if aHm > bHm and aLm < bLm
                found := true
                int sz = array.size(p_N)
                bool identical = false
                if sz > 0
                    int li = sz - 1
                    identical := array.get(p_lo_t1, li) == bLt and array.get(p_lo_v1, li) == bLm and array.get(p_lo_t2, li) == aLt and array.get(p_lo_v2, li) == aLm and array.get(p_up_t1, li) == bHt and array.get(p_up_v1, li) == bHm and array.get(p_up_t2, li) == aHt and array.get(p_up_v2, li) == aHm
                    // same structure re-anchored (same left anchors, new extremes) -> supersede
                    if not identical and array.get(p_lo_t1, li) == bLt and array.get(p_lo_v1, li) == bLm and array.get(p_up_t1, li) == bHt and array.get(p_up_v1, li) == bHm
                        if array.get(p_lo_st, li) == 0
                            array.set(p_lo_st, li, 3)
                            f_retire(array.get(p_lo_ln, li))
                        if array.get(p_up_st, li) == 0
                            array.set(p_up_st, li, 3)
                            f_retire(array.get(p_up_ln, li))
                if not identical
                    // per-side duplicate guard (e.g. DRAM F3 upper == F2 upper)
                    bool lo_dup = false
                    bool up_dup = false
                    if sz > 0
                        for i = 0 to sz - 1
                            if array.get(p_lo_t1, i) == bLt and array.get(p_lo_v1, i) == bLm and array.get(p_lo_t2, i) == aLt and array.get(p_lo_v2, i) == aLm
                                lo_dup := true
                            if array.get(p_up_t1, i) == bHt and array.get(p_up_v1, i) == bHm and array.get(p_up_t2, i) == aHt and array.get(p_up_v2, i) == aHm
                                up_dup := true
                    array.push(p_N, n)
                    array.push(p_born, time)
                    array.push(p_lo_t1, bLt)
                    array.push(p_lo_v1, bLm)
                    array.push(p_lo_t2, aLt)
                    array.push(p_lo_v2, aLm)
                    array.push(p_lo_st, lo_dup ? 4 : 0)
                    array.push(p_lo_ln, lo_dup ? line(na) : f_draw(bLt, bLm, aLt, aLm))
                    array.push(p_up_t1, bHt)
                    array.push(p_up_v1, bHm)
                    array.push(p_up_t2, aHt)
                    array.push(p_up_v2, aHm)
                    array.push(p_up_st, up_dup ? 4 : 0)
                    array.push(p_up_ln, up_dup ? line(na) : f_draw(bHt, bHm, aHt, aHm))
                    if array.size(p_N) > pool_cap
                        line d1 = array.get(p_lo_ln, 0)
                        line d2 = array.get(p_up_ln, 0)
                        if not na(d1)
                            line.delete(d1)
                        if not na(d2)
                            line.delete(d2)
                        array.shift(p_N)
                        array.shift(p_born)
                        array.shift(p_lo_t1)
                        array.shift(p_lo_v1)
                        array.shift(p_lo_t2)
                        array.shift(p_lo_v2)
                        array.shift(p_lo_st)
                        array.shift(p_lo_ln)
                        array.shift(p_up_t1)
                        array.shift(p_up_v1)
                        array.shift(p_up_t2)
                        array.shift(p_up_v2)
                        array.shift(p_up_st)
                        array.shift(p_up_ln)
if base_roll or na(cur_hi)
    cur_hi := high
    cur_lo := low
    cur_hiT := time
    cur_loT := time
else
    if high > cur_hi
        cur_hi := high
        cur_hiT := time
    if low < cur_lo
        cur_lo := low
        cur_loT := time

// --------------------------- position machine --------------------------------
var int pos = 0
var float entry_px = na
bool sig_el = false
bool sig_es = false
bool sig_xl = false
bool sig_xs = false
float x_line = na
int x_n = 0
string x_kind = ''

// exits first (an entry this bar is not exited on the same bar).
// TOUCH = the bar's range CONTAINS the line. DIRECTION-RELATIVE: shorts only
// at alive lower lines BELOW entry; longs only at alive upper lines ABOVE.
int psz = array.size(p_N)
if pos == -1 and psz > 0
    for i = 0 to psz - 1
        if array.get(p_lo_st, i) == 0
            float v = f_lo_val(i)
            if v < entry_px and low <= v and high >= v
                if na(x_line) or v > x_line
                    x_line := v
                    x_n := array.get(p_N, i)
    if not na(x_line)
        pos := 0
        sig_xs := true
        x_kind := 'bf'
if pos == 1 and psz > 0
    for i = 0 to psz - 1
        if array.get(p_up_st, i) == 0
            float v = f_up_val(i)
            if v > entry_px and low <= v and high >= v
                if na(x_line) or v < x_line
                    x_line := v
                    x_n := array.get(p_N, i)
    if not na(x_line)
        pos := 0
        sig_xl := true
        x_kind := 'bf'
if pos == 1 and flip_backstop and gate_dn and barstate.isconfirmed
    pos := 0
    sig_xl := true
    x_kind := 'flip'
if pos == -1 and flip_backstop and gate_up and barstate.isconfirmed
    pos := 0
    sig_xs := true
    x_kind := 'flip'

// lifecycle: ANY containment touch consumes an alive line (it is a tested
// level now); a confirmed close beyond an alive line marks it crossed.
if psz > 0
    for i = 0 to psz - 1
        if array.get(p_lo_st, i) == 0
            float v = f_lo_val(i)
            if low <= v and high >= v
                array.set(p_lo_st, i, 1)
                f_retire(array.get(p_lo_ln, i))
            else if barstate.isconfirmed and close < v
                array.set(p_lo_st, i, 2)
                f_retire(array.get(p_lo_ln, i))
        if array.get(p_up_st, i) == 0
            float v = f_up_val(i)
            if low <= v and high >= v
                array.set(p_up_st, i, 1)
                f_retire(array.get(p_up_ln, i))
            else if barstate.isconfirmed and close > v
                array.set(p_up_st, i, 2)
                f_retire(array.get(p_up_ln, i))

float trig_l = prev_ah + syminfo.mintick
float trig_s = prev_al - syminfo.mintick
if pos == 0 and not sig_xl and not sig_xs
    if allow_long and gate_up and not na(prev_ah) and high >= trig_l
        pos := 1
        entry_px := trig_l
        sig_el := true
    else if allow_short and gate_dn and not na(prev_al) and low <= trig_s
        pos := -1
        entry_px := trig_s
        sig_es := true

// roll the arm snapshot LAST (corrected clock)
if arm_last
    prev_ah := a_hi
    prev_al := a_lo

// ------------------------- heads-up proximity --------------------------------
float near_lo = na
float near_up = na
if psz > 0
    if pos == -1
        for i = 0 to psz - 1
            if array.get(p_lo_st, i) == 0
                float v = f_lo_val(i)
                if v < entry_px and v < low and (na(near_lo) or v > near_lo)
                    near_lo := v
    if pos == 1
        for i = 0 to psz - 1
            if array.get(p_up_st, i) == 0
                float v = f_up_val(i)
                if v > entry_px and v > high and (na(near_up) or v < near_up)
                    near_up := v
bool warn_s = warn_pct > 0 and pos == -1 and not na(near_lo) and (low - near_lo) / low * 100 <= warn_pct
bool warn_l = warn_pct > 0 and pos == 1 and not na(near_up) and (near_up - high) / high * 100 <= warn_pct

// ------------------------------ visuals --------------------------------------
bgcolor(show_bg and pos == 1 ? color.new(c_long, 92) : show_bg and pos == -1 ? color.new(c_short, 92) : na)
plotshape(sig_el, 'Enter Long', style = shape.labelup, color = c_long, text = 'LONG', textcolor = color.white, location = location.belowbar, size = size.tiny)
plotshape(sig_es, 'Enter Short', style = shape.labeldown, color = c_short, text = 'SHORT', textcolor = color.white, location = location.abovebar, size = size.tiny)
plotchar(warn_s, 'Heads-up (short near line)', '!', location.belowbar, color.new(color.yellow, 20), size = size.tiny)
plotchar(warn_l, 'Heads-up (long near line)', '!', location.abovebar, color.new(color.yellow, 20), size = size.tiny)
if sig_xl
    label.new(bar_index, high, x_kind == 'flip' ? 'Flip L Exit' : 'BF L Exit', style = label.style_label_down, color = color.new(c_long, 20), textcolor = color.white, size = size.small,
      tooltip = x_kind == 'flip' ? 'Flip backstop: full opposite alignment at a confirmed close; no BF line reached.' : 'Long exit: bar range contains the N=' + str.tostring(x_n) + ' compound upper line at ' + str.tostring(x_line, format.mintick) + ' (above entry ' + str.tostring(entry_px, format.mintick) + ').')
if sig_xs
    label.new(bar_index, low, x_kind == 'flip' ? 'Flip S Exit' : 'BF S Exit', style = label.style_label_up, color = color.new(c_short, 20), textcolor = color.white, size = size.small,
      tooltip = x_kind == 'flip' ? 'Flip backstop: full opposite alignment at a confirmed close; no BF line reached.' : 'Short exit: bar range contains the N=' + str.tostring(x_n) + ' compound lower line at ' + str.tostring(x_line, format.mintick) + ' (below entry ' + str.tostring(entry_px, format.mintick) + ').')

// ------------------------------ alerts ---------------------------------------
alertcondition(sig_el, 'Enter Long', 'TFC-BF: LONG entry (gate aligned, arm break)')
alertcondition(sig_es, 'Enter Short', 'TFC-BF: SHORT entry (gate aligned, arm break)')
alertcondition(sig_xl, 'Exit Long', 'TFC-BF: EXIT LONG (BF line or flip backstop)')
alertcondition(sig_xs, 'Exit Short', 'TFC-BF: EXIT SHORT (BF line or flip backstop)')
alertcondition(sig_el or sig_es or sig_xl or sig_xs, 'Any signal', 'TFC-BF: signal')

// ------------------------------ status table ---------------------------------
var table tbl = na
if barstate.islast and show_table
    if na(tbl)
        tbl := table.new(position.top_right, 1, 4, bgcolor = color.new(color.black, 30), border_width = 1)
    string s_pos = pos == 1 ? 'LONG' : pos == -1 ? 'SHORT' : 'flat'
    string s_gate = gate_up ? 'gate UP' : gate_dn ? 'gate DOWN' : 'gate grey'
    // nearest alive lines around price (context regardless of position)
    float ctx_lo = na
    float ctx_up = na
    int alive_n = 0
    if psz > 0
        for i = 0 to psz - 1
            if array.get(p_lo_st, i) == 0
                alive_n += 1
                float v = f_lo_val(i)
                if v < close and (na(ctx_lo) or v > ctx_lo)
                    ctx_lo := v
            if array.get(p_up_st, i) == 0
                float v = f_up_val(i)
                if v > close and (na(ctx_up) or v < ctx_up)
                    ctx_up := v
    table.cell(tbl, 0, 0, 'TFC-BF [TVB-14] ' + tf_base + '-pool', text_color = color.white, text_size = size.small)
    table.cell(tbl, 0, 1, s_pos + ' | ' + s_gate, text_color = color.silver, text_size = size.tiny)
    table.cell(tbl, 0, 2, 'next line dn ' + (na(ctx_lo) ? '--' : str.tostring(ctx_lo, format.mintick)) + ' | up ' + (na(ctx_up) ? '--' : str.tostring(ctx_up, format.mintick)), text_color = color.silver, text_size = size.tiny)
    table.cell(tbl, 0, 3, str.tostring(array.size(p_N)) + ' formations, ' + str.tostring(alive_n) + ' alive sides', text_color = color.silver, text_size = size.tiny)
