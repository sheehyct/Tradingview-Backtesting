//@version=6
// =====================================================================================
// Baseline Timeframe-Continuity Strategy  [TVB-1]      (canonical source -- TVB-3 rev)
// -------------------------------------------------------------------------------------
// Purpose : CONTROL baseline for the timeframe-continuity exploration (charter Section 5).
//           {2-trigger (raw level break) + TFO FTC-gate + state-stop} -- single layer,
//           structurally 1x (percent_of_equity 100; no sizing input until the charter 3.3
//           sizing work starts), fixed a-priori timeframe set. Built to be ablated AGAINST
//           and broken, not deployed.
// Gate    : FTFC = chart close vs each ENABLED timeframe's CURRENT period open
//           (charter Section 3.2; TFO-style close > period-open). Aggregate up/down/grey.
//           TVB-3 FIX: period opens are reconstructed LOCALLY via
//           ta.valuewhen(timeframe.change(tf), open, 0) -- NO request.security. The v13
//           gate used request.security(tf, open, lookahead_off), which returns the PRIOR
//           period's open on historical bars (verified empirically, TVB-3 P2a: D-only and
//           60m-only isolations, zero unexplained rows) while returning the developing
//           period's open on realtime bars -- i.e. STALE and backtest != live. All TVB-1/2
//           numbers characterize that stale gate. Local reconstruction uses chart data
//           only: no lookahead question, backtest == live by construction.
//           Warmup: the gate is na (neutral -> no trades) until the first period boundary
//           of each enabled TF inside loaded history (worst ~1 month for M); the first
//           PARTIALLY-loaded period reads its first loaded bar's open.
// Trigger : Raw prior-bar level break via breakout STOP orders at high + 1 tick /
//           low - 1 tick (strat-methodology: trigger = level + one tick; enforces the
//           strict H > H[1] break -- a stop AT the level fills on equality, not a 2U).
//           Once-per-bar placement, NO calc_on_every_tick (charter Section 3.4).
// Stop    : State-stop, CLOSE-based -> exit when the gate de-aligns (grey/opposite) at
//           bar close; with process_orders_on_close = false the exit fills at the next
//           bar's open (charter Section 3.5). No fixed target.
// Guard   : Chart TF must be <= every ENABLED gate TF (runtime.error otherwise).
//           >> Chart TF should EQUAL the lowest enabled TF for the intended reading. <<
// Presets : Control A = M/W/D/60 on a 60m chart ;  Control B = 60/30/15 on a 15m chart.
//           File defaults below = Control B. Runs set enables/commission explicitly.
// Fees    : commission_value default 0.1 (%/fill) is the HIP-3 BRIDGE-COMPARISON rate
//           only. GROUND TRUTH (TVB-2, HL fills classified by the `crossed` flag): the
//           real xyz taker rate is ~0.0086% modal / 0.0125% notional-weighted ALL-IN,
//           ~10x below 0.1%. Sweep the commission input per run; NEVER report a
//           single-fee verdict (%-equity sizing compounds fees: equity x= (1-f)^(2N)).
// Traps   : slippage = 1 tick per market/stop fill is baked in below (TVB-3 settings
//           dump). Bar magnifier is OFF unless enabled in properties -- intrabar fill
//           fidelity check still pending (charter Section 7.2).
// =====================================================================================

strategy('Baseline TFC [TVB-1]', overlay = true,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 100,
     initial_capital    = 10000,
     pyramiding         = 0,
     process_orders_on_close = false,
     calc_on_every_tick = false,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.1,
     slippage           = 1,
     margin_long        = 0,     // TVB-3: margin enforcement OFF. At 100%-equity sizing the
     margin_short       = 0)     // emulator margin-called every short on its first adverse
                                 // tick, and one margin-call/close race left an orphan
                                 // residual position that deadlocked the strategy for
                                 // months (no entries while not flat, no matching close
                                 // id). Margin realism is not this control's concern at 1x;
                                 // the state-stop must be the ONLY exit.

// ----------------------------------- Inputs -----------------------------------
var string g_dir = 'Direction'
allow_long  = input.bool(true, 'Allow Long',  group = g_dir)
allow_short = input.bool(true, 'Allow Short', group = g_dir)

var string g_tf = 'Gate Timeframes (FTFC set)  --  enable lowest = chart TF'
// Defaults below = Control B (60/30/15). For Control A: chart 60m, enable M/W/D/60.
y1  = input.bool(false, '', inline = '1', group = g_tf)
tf1 = input.timeframe('M',  'TF 1', inline = '1', group = g_tf)
y2  = input.bool(false, '', inline = '2', group = g_tf)
tf2 = input.timeframe('W',  'TF 2', inline = '2', group = g_tf)
y3  = input.bool(false, '', inline = '3', group = g_tf)
tf3 = input.timeframe('D',  'TF 3', inline = '3', group = g_tf)
y4  = input.bool(true,  '', inline = '4', group = g_tf)
tf4 = input.timeframe('60', 'TF 4', inline = '4', group = g_tf)
y5  = input.bool(true,  '', inline = '5', group = g_tf)
tf5 = input.timeframe('30', 'TF 5', inline = '5', group = g_tf)
y6  = input.bool(true,  '', inline = '6', group = g_tf)
tf6 = input.timeframe('15', 'TF 6', inline = '6', group = g_tf)

var string g_viz = 'Display'
show_state  = input.bool(true, 'Color bars by gate state', group = g_viz)
show_levels = input.bool(true, 'Plot FTFC floor/ceiling (period opens)', group = g_viz)

// ------------------- Guard: chart TF <= every ENABLED gate TF -------------------
// Misconfigured runs must fail LOUDLY (runtime error), never read silently wrong.
f_guard(simple string tf, simple bool enabled) =>
    if enabled and timeframe.in_seconds(tf) < timeframe.in_seconds(timeframe.period)
        runtime.error('Gate TF "' + tf + '" is finer than the chart TF (' + timeframe.period + '). Chart TF must be <= every enabled gate TF.')
f_guard(tf1, y1)
f_guard(tf2, y2)
f_guard(tf3, y3)
f_guard(tf4, y4)
f_guard(tf5, y5)
f_guard(tf6, y6)

// ------------- Gate (FTFC): LOCAL period-open reconstruction (TVB-3 fix) -------------
// The CURRENT period's open = the chart open on the first bar of the period. Chart-local
// data only -- no request.security, no lookahead question, no backtest/live asymmetry.
// Same-TF case (tf == chart TF): timeframe.change fires every bar -> current bar's open.
f_open(simple string tf) =>
    ta.valuewhen(timeframe.change(tf), open, 0)

o1 = f_open(tf1)
o2 = f_open(tf2)
o3 = f_open(tf3)
o4 = f_open(tf4)
o5 = f_open(tf5)
o6 = f_open(tf6)

use_arr  = array.from(y1, y2, y3, y4, y5, y6)
open_arr = array.from(o1, o2, o3, o4, o5, o6)

ftfc_up = true
ftfc_dn = true
int n_enabled = 0
float hi_open = na   // highest enabled period-open -> price floor for FTFC up
float lo_open = na   // lowest  enabled period-open -> price ceiling for FTFC down
for i = 0 to array.size(use_arr) - 1 by 1
    if array.get(use_arr, i)
        n_enabled += 1
        op = array.get(open_arr, i)
        hi_open := na(hi_open) ? op : math.max(hi_open, op)
        lo_open := na(lo_open) ? op : math.min(lo_open, op)
        if close > op
            ftfc_dn := false        // this TF is green -> kills a down-alignment
        else if close < op
            ftfc_up := false        // this TF is red   -> kills an up-alignment
        else
            ftfc_up := false        // at the open, or op still na (warmup) -> neutral
            ftfc_dn := false
if n_enabled == 0
    ftfc_up := false
    ftfc_dn := false

// ----------------------------------- State-stop exit -----------------------------------
long_open  = strategy.position_size > 0
short_open = strategy.position_size < 0

if long_open and not ftfc_up
    strategy.close('Long', comment = 'state-stop')
if short_open and not ftfc_dn
    strategy.close('Short', comment = 'state-stop')

// ----------------------------------- Trigger + entries -----------------------------------
// While flat and gate-aligned, arm a breakout stop ONE TICK beyond the just-closed bar's
// extreme. The broker emulator fills it intrabar the instant price trades through the
// level (charter 3.4). Re-armed each bar to track the most recent closed bar.
flat = strategy.position_size == 0
if flat
    if allow_long and ftfc_up
        strategy.entry('Long', strategy.long, stop = high + syminfo.mintick)
    else
        strategy.cancel('Long')
    if allow_short and ftfc_dn
        strategy.entry('Short', strategy.short, stop = low - syminfo.mintick)
    else
        strategy.cancel('Short')
else
    strategy.cancel('Long')
    strategy.cancel('Short')

// ----------------------------------- Visualization (audit aid) -----------------------------------
state_col = ftfc_up ? color.new(color.green, 55) : ftfc_dn ? color.new(color.red, 55) : color.new(color.gray, 70)
barcolor(show_state ? state_col : na)

plot(show_levels ? hi_open : na, 'FTFC up floor (max open)', color = color.new(color.green, 40), style = plot.style_stepline)
plot(show_levels ? lo_open : na, 'FTFC dn ceiling (min open)', color = color.new(color.red, 40), style = plot.style_stepline)
