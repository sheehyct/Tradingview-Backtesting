//@version=6
// =====================================================================================
// TFC Baseline+Regime [TVB-4]                          (canonical source -- TVB-4 rev)
// -------------------------------------------------------------------------------------
// Purpose : CONTROL baseline + optional REGIME LAYER (charter Section 3.3) for the
//           timeframe-continuity exploration. Defaults = Control B with regime OFF,
//           i.e. byte-equivalent behavior to the TVB-3 corrected control. The regime
//           layer is an ABLATION (charter S5), not a tournament entry.
// Gate    : FTFC = chart close vs each ENABLED timeframe's CURRENT period open,
//           reconstructed LOCALLY via ta.valuewhen(timeframe.change(tf), open, 0)
//           (TVB-3 fix; no request.security, backtest == live by construction).
//           Warmup: a gate TF is neutral (na open -> grey) until its first period
//           boundary inside loaded history.
// Regime  : Same FTFC measurement over an HTF set (a-priori M/W/D; charter 3.3).
//           reg_mode: off = control; stand_aside = entries only when regime is
//           aligned WITH the trade direction, grey blocks both; size_down = aligned
//           full size, grey trades BOTH directions at grey_size_pct (fixed a-priori
//           50%, Carver half-forecast), opposite blocked. Exits are NOT regime-gated
//           in v1 (reg_exit default false; ablation knob only).
// Trigger : Raw prior-bar level break via breakout STOP orders at high + 1 tick /
//           low - 1 tick (strict break; once-per-bar, no calc_on_every_tick).
// Stop    : State-stop, CLOSE-based; fills next bar open. No fixed target.
// Guard   : Chart TF must be <= AND must TILE every enabled gate TF (both layers):
//           intraday gate TFs must be integer multiples of the chart TF; D/W/M gate
//           TFs require the chart TF to divide 1D (Codex TVB-3 finding 1). Misaligned
//           configs fail LOUDLY.
// Presets : Control A = M/W/D/60 on 60m ; Control B = 60/30/15 on 15m (file default).
// Fees    : commission_value default 0.1 (%/fill) is the bridge-comparison rate only.
//           Real xyz taker ~0.0086% modal / 0.0125% notional-weighted. Sweep per run;
//           NEVER report a single-fee verdict.
// Traps   : slippage = 1 tick/fill baked in. Bar magnifier verified immaterial for
//           this state-stop architecture (TVB-4 preflight 1); keep OFF. Margin 0/0 --
//           the state-stop must be the ONLY exit (TVB-3 deadlock artifact).
// =====================================================================================

strategy('TFC Baseline+Regime [TVB-4]', overlay = true,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 100,
     initial_capital    = 10000,
     pyramiding         = 0,
     process_orders_on_close = false,
     calc_on_every_tick = false,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.1,
     slippage           = 1,
     margin_long        = 0,
     margin_short       = 0)

// ----------------------------------- Inputs -----------------------------------
var string g_dir = 'Direction'
allow_long  = input.bool(true, 'Allow Long',  group = g_dir)
allow_short = input.bool(true, 'Allow Short', group = g_dir)

var string g_tf = 'Execution gate TFs (FTFC set)  --  chart TF = lowest enabled'
y1  = input.bool(false, '', inline = '1', group = g_tf)
tf1 = input.timeframe('M',  'TF 1', inline = '1', group = g_tf)
y2  = input.bool(false, '', inline = '2', group = g_tf)
tf2 = input.timeframe('W',  'TF 2', inline = '2', group = g_tf)
y3  = input.bool(false, '', inline = '3', group = g_tf)
tf3 = input.timeframe('D',  'TF 3', inline = '3', group = g_tf)
y4  = input.bool(true,  '', inline = '4', group = g_tf)
tf4 = input.timeframe('60', 'TF 4', inline = '4', group = g_tf)
y5  = input.bool(true,  '', inline = '5', group = g_tf)
tf5 = input.timeframe('30', 'TF 5', inline = '5', group = g_tf)
y6  = input.bool(true,  '', inline = '6', group = g_tf)
tf6 = input.timeframe('15', 'TF 6', inline = '6', group = g_tf)

var string g_viz = 'Display'
show_state  = input.bool(true, 'Color bars by gate state', group = g_viz)
show_levels = input.bool(true, 'Plot FTFC floor/ceiling (period opens)', group = g_viz)

// Regime layer (appended AFTER existing inputs so in_0..in_15 keep their ids;
// strategy properties renumber by +9 -- RE-DERIVE the id map after compiling).
var string g_reg = 'Regime layer (charter 3.3) -- M/W/D a-priori, do not tune'
reg_mode = input.string('off', 'Regime mode', options = ['off', 'stand_aside', 'size_down'], group = g_reg)
rg1  = input.bool(true, '', inline = 'r1', group = g_reg)
rtf1 = input.timeframe('M', 'Regime TF 1', inline = 'r1', group = g_reg)
rg2  = input.bool(true, '', inline = 'r2', group = g_reg)
rtf2 = input.timeframe('W', 'Regime TF 2', inline = 'r2', group = g_reg)
rg3  = input.bool(true, '', inline = 'r3', group = g_reg)
rtf3 = input.timeframe('D', 'Regime TF 3', inline = 'r3', group = g_reg)
grey_size_pct = input.float(50, 'Grey size % (size_down mode; FIXED a-priori)', minval = 0, maxval = 100, group = g_reg)
reg_exit = input.bool(false, 'Exit on regime-opposite (ablation knob -- keep OFF in v1)', group = g_reg)

// ------------- Guard: chart TF <= AND tiling every ENABLED gate TF -------------
// Misconfigured runs must fail LOUDLY (runtime error), never read silently wrong.
// Alignment (Codex TVB-3 finding 1): the local period-open reconstruction is exact
// only when chart bars tile the gate period. D/W/M periods start on a day boundary
// (00:00 UTC on these 24/7 perps) -> chart TF must divide 1D; intraday gate TFs must
// be integer multiples of the chart TF.
f_guard(simple string tf, simple bool enabled) =>
    if enabled
        cs = timeframe.in_seconds(timeframe.period)
        gs = timeframe.in_seconds(tf)
        if gs < cs
            runtime.error('Gate TF "' + tf + '" is finer than the chart TF (' + timeframe.period + '). Chart TF must be <= every enabled gate TF.')
        if gs >= 86400
            if 86400 % cs != 0
                runtime.error('Chart TF ' + timeframe.period + ' does not divide 1D -- D/W/M period-open reconstruction would be approximate.')
        else if gs % cs != 0
            runtime.error('Gate TF "' + tf + '" is not an integer multiple of the chart TF (' + timeframe.period + ') -- reconstruction would be approximate.')
f_guard(tf1, y1)
f_guard(tf2, y2)
f_guard(tf3, y3)
f_guard(tf4, y4)
f_guard(tf5, y5)
f_guard(tf6, y6)
if reg_mode != 'off'
    f_guard(rtf1, rg1)
    f_guard(rtf2, rg2)
    f_guard(rtf3, rg3)

// ------------- Gate (FTFC): LOCAL period-open reconstruction (TVB-3 fix) -------------
f_open(simple string tf) =>
    ta.valuewhen(timeframe.change(tf), open, 0)

o1 = f_open(tf1)
o2 = f_open(tf2)
o3 = f_open(tf3)
o4 = f_open(tf4)
o5 = f_open(tf5)
o6 = f_open(tf6)

use_arr  = array.from(y1, y2, y3, y4, y5, y6)
open_arr = array.from(o1, o2, o3, o4, o5, o6)

// Execution-layer aggregation: kept VERBATIM from the TVB-3 control (also computes the
// plotted floor/ceiling levels) -- regression safety over de-duplication.
ftfc_up = true
ftfc_dn = true
int n_enabled = 0
float hi_open = na
float lo_open = na
for i = 0 to array.size(use_arr) - 1 by 1
    if array.get(use_arr, i)
        n_enabled += 1
        op = array.get(open_arr, i)
        hi_open := na(hi_open) ? op : math.max(hi_open, op)
        lo_open := na(lo_open) ? op : math.min(lo_open, op)
        if close > op
            ftfc_dn := false
        else if close < op
            ftfc_up := false
        else
            ftfc_up := false
            ftfc_dn := false
if n_enabled == 0
    ftfc_up := false
    ftfc_dn := false

// ------------------------------- Regime layer (TVB-4) -------------------------------
// Same measurement, HTF set. Warmup (na opens) reads grey => stand_aside blocks entries
// until every enabled regime TF has seeded (MSTR floor Feb 25 -> M seeds Mar 1).
f_agg(u_arr, o_arr) =>
    up = true
    dn = true
    int n = 0
    for i = 0 to array.size(u_arr) - 1 by 1
        if array.get(u_arr, i)
            n += 1
            op = array.get(o_arr, i)
            if close > op
                dn := false
            else if close < op
                up := false
            else
                up := false
                dn := false
    if n == 0
        up := false
        dn := false
    [up, dn]

ro1 = f_open(rtf1)
ro2 = f_open(rtf2)
ro3 = f_open(rtf3)
[reg_up, reg_dn] = f_agg(array.from(rg1, rg2, rg3), array.from(ro1, ro2, ro3))
reg_grey = not reg_up and not reg_dn

// Permission + size (charter 3.3): aligned regime permits ONLY that direction at full
// size; grey per mode; opposite regime blocks. reg_mode == 'off' is the pure control.
long_permit  = reg_mode == 'off' ? true : reg_mode == 'stand_aside' ? reg_up : reg_up or reg_grey
short_permit = reg_mode == 'off' ? true : reg_mode == 'stand_aside' ? reg_dn : reg_dn or reg_grey
size_scale   = reg_mode == 'size_down' and reg_grey ? grey_size_pct / 100.0 : 1.0

// ----------------------------------- State-stop exit -----------------------------------
long_open  = strategy.position_size > 0
short_open = strategy.position_size < 0

if long_open and not ftfc_up
    strategy.close('Long', comment = 'state-stop')
if short_open and not ftfc_dn
    strategy.close('Short', comment = 'state-stop')
if reg_exit and reg_mode != 'off'
    if long_open and reg_dn
        strategy.close('Long', comment = 'regime-exit')
    if short_open and reg_up
        strategy.close('Short', comment = 'regime-exit')

// ----------------------------------- Trigger + entries -----------------------------------
// Full-size entries use the default percent_of_equity sizing (identical to the control
// and identical across modes -- the modes differ ONLY in grey handling). Grey size_down
// entries pass an explicit qty converted at arm-time close (documented approximation,
// confined to grey entries).
flat = strategy.position_size == 0
if flat
    if allow_long and ftfc_up and long_permit
        if size_scale == 1.0
            strategy.entry('Long', strategy.long, stop = high + syminfo.mintick)
        else
            strategy.entry('Long', strategy.long, qty = strategy.equity * size_scale / close, stop = high + syminfo.mintick)
    else
        strategy.cancel('Long')
    if allow_short and ftfc_dn and short_permit
        if size_scale == 1.0
            strategy.entry('Short', strategy.short, stop = low - syminfo.mintick)
        else
            strategy.entry('Short', strategy.short, qty = strategy.equity * size_scale / close, stop = low - syminfo.mintick)
    else
        strategy.cancel('Short')
else
    strategy.cancel('Long')
    strategy.cancel('Short')

// ----------------------------------- Visualization (audit aid) -----------------------------------
state_col = ftfc_up ? color.new(color.green, 55) : ftfc_dn ? color.new(color.red, 55) : color.new(color.gray, 70)
barcolor(show_state ? state_col : na)
reg_col = reg_mode == 'off' ? na : reg_up ? color.new(color.green, 92) : reg_dn ? color.new(color.red, 92) : color.new(color.gray, 92)
bgcolor(reg_col)

plot(show_levels ? hi_open : na, 'FTFC up floor (max open)', color = color.new(color.green, 40), style = plot.style_stepline)
plot(show_levels ? lo_open : na, 'FTFC dn ceiling (min open)', color = color.new(color.red, 40), style = plot.style_stepline)
