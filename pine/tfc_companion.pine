//@version=6
// =====================================================================================
// TFC Companion [TVB-9]                              (indicator port of the baseline)
// -------------------------------------------------------------------------------------
// Purpose : MANUAL-TRADING companion to pine/baseline_continuity.pine (pv20 anchor).
//           Shows, live on any chart, exactly what the backtested strategy sees and
//           does: the FTFC exec gate, the regime permits, the armed one-bar breakout
//           trigger, simulated fills/exits, and the governor ratchet levels.
//           NO new detection logic -- the gate/trigger/stop/governor semantics are
//           copied from the deployed strategy (TVB-1 charter reconciliation: FTFC =
//           chart close vs each enabled TF's CURRENT period open).
// Fidelity: the strategy's TRADE SEQUENCE is fee-independent and its governor arms on
//           GROSS profit (TVB-7 adjudication), so this indicator replicates the
//           position state bar-for-bar with NO equity model. Fill prices mirror the
//           deployed staging's adverse slippage (slip_ticks input, default 1) ONLY to
//           preserve governor win/loss semantics on scratch trades.
// Live     : entries fill INTRABAR the instant price trades through the armed stop
//           (charter S3.4 -- high>stop never un-happens); everything close-based
//           (gate state, state-stop decision, next-bar arming) is PROVISIONAL until
//           bar close, exactly like the strategy's once-per-bar evaluation.
// Alerts   : alertcondition() only (charter S4). Recommended settings when creating:
//           entry fills -> "Once Per Bar"; exit-decision / armed -> "Once Per Bar Close".
// Warmup   : a gate TF is neutral (grey) until its first period boundary inside loaded
//           history (M seeds at the first month roll, etc.) -- same as the strategy.
// Defaults : R1E3 two-layer (exec 240/120/60 + regime M/W/D stand_aside, 60m chart),
//           governor OFF (regression-anchor convention). All presets reachable via
//           inputs; the guard fails LOUDLY on chart/gate misalignment.
// =====================================================================================

indicator('TFC Companion [TVB-9]', overlay = true)

// ----------------------------------- Inputs -----------------------------------
var string g_dir = 'Direction'
allow_long  = input.bool(true, 'Allow Long',  group = g_dir)
allow_short = input.bool(true, 'Allow Short', group = g_dir)

var string g_tf = 'Execution gate TFs (FTFC set)  --  chart TF = lowest enabled'
y1  = input.bool(true,  '', inline = '1', group = g_tf)
tf1 = input.timeframe('240', 'TF 1', inline = '1', group = g_tf)
y2  = input.bool(true,  '', inline = '2', group = g_tf)
tf2 = input.timeframe('120', 'TF 2', inline = '2', group = g_tf)
y3  = input.bool(true,  '', inline = '3', group = g_tf)
tf3 = input.timeframe('60', 'TF 3', inline = '3', group = g_tf)
y4  = input.bool(false, '', inline = '4', group = g_tf)
tf4 = input.timeframe('M',  'TF 4', inline = '4', group = g_tf)
y5  = input.bool(false, '', inline = '5', group = g_tf)
tf5 = input.timeframe('W',  'TF 5', inline = '5', group = g_tf)
y6  = input.bool(false, '', inline = '6', group = g_tf)
tf6 = input.timeframe('D',  'TF 6', inline = '6', group = g_tf)

var string g_reg = 'Regime layer (charter 3.3) -- M/W/D a-priori, do not tune'
reg_mode = input.string('stand_aside', 'Regime mode', options = ['off', 'stand_aside', 'size_down'], group = g_reg)
rg1  = input.bool(true, '', inline = 'r1', group = g_reg)
rtf1 = input.timeframe('M', 'Regime TF 1', inline = 'r1', group = g_reg)
rg2  = input.bool(true, '', inline = 'r2', group = g_reg)
rtf2 = input.timeframe('W', 'Regime TF 2', inline = 'r2', group = g_reg)
rg3  = input.bool(true, '', inline = 'r3', group = g_reg)
rtf3 = input.timeframe('D', 'Regime TF 3', inline = 'r3', group = g_reg)

var string g_gov = 'Re-entry governor (TVB-6, charter S8) -- zero-parameter ratchet'
gov_mode   = input.string('off', 'Governor mode', options = ['off', 'ratchet'], group = g_gov)
slip_ticks = input.int(1, 'Slippage ticks (governor gross fidelity only)', minval = 0, group = g_gov)

var string g_viz = 'Display'
show_state   = input.bool(true, 'Color bars by gate state', group = g_viz)
show_levels  = input.bool(true, 'Plot FTFC floor/ceiling (period opens)', group = g_viz)
show_trigger = input.bool(true, 'Plot armed trigger level', group = g_viz)
show_marks   = input.bool(true, 'Plot simulated entry/exit markers', group = g_viz)
show_ratchet = input.bool(true, 'Plot governor ratchet levels', group = g_viz)
show_table   = input.bool(true, 'Show status table', group = g_viz)

// ------------- Guard: chart TF <= AND tiling every ENABLED gate TF -------------
// Verbatim from the strategy: misconfigured charts fail LOUDLY, never read wrong.
f_guard(simple string tf, simple bool enabled) =>
    if enabled
        cs = timeframe.in_seconds(timeframe.period)
        gs = timeframe.in_seconds(tf)
        if gs < cs
            runtime.error('Gate TF "' + tf + '" is finer than the chart TF (' + timeframe.period + '). Chart TF must be <= every enabled gate TF.')
        if gs >= 86400
            if 86400 % cs != 0
                runtime.error('Chart TF ' + timeframe.period + ' does not divide 1D -- D/W/M period-open reconstruction would be approximate.')
        else if gs % cs != 0
            runtime.error('Gate TF "' + tf + '" is not an integer multiple of the chart TF (' + timeframe.period + ') -- reconstruction would be approximate.')
f_guard(tf1, y1)
f_guard(tf2, y2)
f_guard(tf3, y3)
f_guard(tf4, y4)
f_guard(tf5, y5)
f_guard(tf6, y6)
if reg_mode != 'off'
    f_guard(rtf1, rg1)
    f_guard(rtf2, rg2)
    f_guard(rtf3, rg3)

// ------------- Gate (FTFC): LOCAL period-open reconstruction (TVB-3 fix) -------------
f_open(simple string tf) =>
    ta.valuewhen(timeframe.change(tf), open, 0)

o1 = f_open(tf1)
o2 = f_open(tf2)
o3 = f_open(tf3)
o4 = f_open(tf4)
o5 = f_open(tf5)
o6 = f_open(tf6)

use_arr  = array.from(y1, y2, y3, y4, y5, y6)
open_arr = array.from(o1, o2, o3, o4, o5, o6)

ftfc_up = true
ftfc_dn = true
int n_enabled = 0
float hi_open = na
float lo_open = na
for i = 0 to array.size(use_arr) - 1 by 1
    if array.get(use_arr, i)
        n_enabled += 1
        op = array.get(open_arr, i)
        hi_open := na(hi_open) ? op : math.max(hi_open, op)
        lo_open := na(lo_open) ? op : math.min(lo_open, op)
        if close > op
            ftfc_dn := false
        else if close < op
            ftfc_up := false
        else
            ftfc_up := false
            ftfc_dn := false
if n_enabled == 0
    ftfc_up := false
    ftfc_dn := false

// ------------------------------- Regime layer -------------------------------
f_agg(u_arr, o_arr) =>
    up = true
    dn = true
    int n = 0
    for i = 0 to array.size(u_arr) - 1 by 1
        if array.get(u_arr, i)
            n += 1
            op = array.get(o_arr, i)
            if close > op
                dn := false
            else if close < op
                up := false
            else
                up := false
                dn := false
    if n == 0
        up := false
        dn := false
    [up, dn]

ro1 = f_open(rtf1)
ro2 = f_open(rtf2)
ro3 = f_open(rtf3)
[reg_up, reg_dn] = f_agg(array.from(rg1, rg2, rg3), array.from(ro1, ro2, ro3))
reg_grey = not reg_up and not reg_dn

long_permit  = reg_mode == 'off' ? true : reg_mode == 'stand_aside' ? reg_up : reg_up or reg_grey
short_permit = reg_mode == 'off' ? true : reg_mode == 'stand_aside' ? reg_dn : reg_dn or reg_grey

// --------------------- Position-state machine (strategy replica) ---------------------
// Mirrors the deployed strategy's execution model exactly (dump-verified in the tfc/
// Python port, gate 8/8): orders decided at close execute from the NEXT bar; exits
// fill at next-bar open; the armed breakout STOP lives exactly one bar and fills
// intrabar at the stop, or at the open when the bar opens through it; entries arm
// only when flat. Governor v2: loss-arm (gross, scratch counts as loss) BEFORE the
// same-bar alignment reset; ratchet level = the TRIGGER, not the fill.
slip = slip_ticks * syminfo.mintick

var int   pos           = 0      // +1 long, -1 short, 0 flat
var float ep            = na     // entry fill price (slippage-adjusted)
var bool  pending_exit  = false
var int   armed         = 0      // stop armed for THIS bar: +1 / -1 / 0
var float stop_price    = na     // the armed trigger level
var float ratchet_long  = na
var float ratchet_short = na

// Phase A -- fills at this bar's open (state from prior close is committed; the
// intrabar fill check high>=stop / low<=stop is monotonic, so live ticks are safe).
bool fill_long  = false
bool fill_short = false
bool exit_fill  = false
if pending_exit and pos != 0
    xp = pos > 0 ? open - slip : open + slip
    gross_win = pos > 0 ? xp > ep : xp < ep
    // a win CLEARS any standing ratchet; a loss (scratch included -- the level did
    // not prove itself) ratchets at the failed trade's TRIGGER (stop_price still
    // holds it: arming only happens flat, so it is never overwritten in-trade)
    if pos > 0
        ratchet_long := gross_win ? na : stop_price
    else
        ratchet_short := gross_win ? na : stop_price
    exit_fill := true
    pos := 0
    pending_exit := false
else if armed > 0
    if open > stop_price
        ep := open + slip
        fill_long := true
    else if high >= stop_price
        ep := stop_price + slip
        fill_long := true
    if fill_long
        pos := 1
else if armed < 0
    if open < stop_price
        ep := open - slip
        fill_short := true
    else if low <= stop_price
        ep := stop_price - slip
        fill_short := true
    if fill_short
        pos := -1

// Phase B -- script logic at this bar's close (provisional intrabar, commits at close).
// 1) state-stop decision (fills next bar open)
if pos > 0 and not ftfc_up
    pending_exit := true
if pos < 0 and not ftfc_dn
    pending_exit := true
// 2) governor alignment reset -- AFTER loss-arm (which ran in Phase A on the exit bar)
if ftfc_dn
    ratchet_long := na
if ftfc_up
    ratchet_short := na
// 3) arm the one-bar breakout stop -- flat only, long priority (mirrors the strategy)
armed := 0
gov = gov_mode == 'ratchet'
gl_ok = not gov or na(ratchet_long)  or high + syminfo.mintick > ratchet_long
gs_ok = not gov or na(ratchet_short) or low - syminfo.mintick < ratchet_short
if pos == 0 and not pending_exit
    if allow_long and ftfc_up and long_permit and gl_ok
        armed := 1
        stop_price := high + syminfo.mintick
    else if allow_short and ftfc_dn and short_permit and gs_ok
        armed := -1
        stop_price := low - syminfo.mintick

// ----------------------------------- Visualization -----------------------------------
state_col = ftfc_up ? color.new(color.green, 55) : ftfc_dn ? color.new(color.red, 55) : color.new(color.gray, 70)
barcolor(show_state ? state_col : na)
reg_col = reg_mode == 'off' ? na : reg_up ? color.new(color.green, 92) : reg_dn ? color.new(color.red, 92) : color.new(color.gray, 92)
bgcolor(reg_col)

plot(show_levels ? hi_open : na, 'FTFC up floor (max open)',   color = color.new(color.green, 40), style = plot.style_stepline)
plot(show_levels ? lo_open : na, 'FTFC dn ceiling (min open)', color = color.new(color.red, 40),   style = plot.style_stepline)

// armed trigger for the NEXT bar (drawn on the arming bar), entry price while in a trade
plot(show_trigger and armed != 0 ? stop_price : na, 'Armed trigger (next bar)', color = color.new(color.orange, 0), style = plot.style_circles, linewidth = 2)
plot(show_trigger and pos != 0 ? ep : na, 'Entry fill', color = color.new(color.blue, 30), style = plot.style_linebr)

plotshape(show_marks and fill_long,  'Sim long entry',  shape.triangleup,   location.belowbar, color.new(color.green, 0), size = size.small)
plotshape(show_marks and fill_short, 'Sim short entry', shape.triangledown, location.abovebar, color.new(color.red, 0),   size = size.small)
plotshape(show_marks and exit_fill,  'Sim exit (state-stop fill @ open)', shape.xcross, location.abovebar, color.new(color.gray, 0), size = size.tiny)

plot(show_ratchet and gov ? ratchet_long : na,  'Governor ratchet (long)',  color = color.new(color.teal, 20),   style = plot.style_linebr)
plot(show_ratchet and gov ? ratchet_short : na, 'Governor ratchet (short)', color = color.new(color.maroon, 20), style = plot.style_linebr)

// ----------------------------------- Status table -----------------------------------
f_tf_state(simple bool en, float op) =>
    not en ? '--' : na(op) ? 'warmup' : close > op ? 'UP' : close < op ? 'DOWN' : 'flat'

var table t = table.new(position.top_right, 2, 12, bgcolor = color.new(color.black, 20), border_width = 1, border_color = color.new(color.gray, 60))
f_cell(int r, string k, string v, color c) =>
    table.cell(t, 0, r, k, text_color = color.white, text_size = size.small, text_halign = text.align_left)
    table.cell(t, 1, r, v, text_color = c, text_size = size.small)

if show_table and barstate.islast
    exec_txt = ftfc_up ? 'ALIGNED UP' : ftfc_dn ? 'ALIGNED DOWN' : 'GREY'
    exec_c   = ftfc_up ? color.lime : ftfc_dn ? color.red : color.gray
    reg_txt  = reg_mode == 'off' ? 'off' : reg_up ? 'UP' : reg_dn ? 'DOWN' : 'GREY'
    reg_c    = reg_mode == 'off' ? color.gray : reg_up ? color.lime : reg_dn ? color.red : color.gray
    pos_txt  = pos > 0 ? 'LONG @ ' + str.tostring(ep, format.mintick) : pos < 0 ? 'SHORT @ ' + str.tostring(ep, format.mintick) : 'FLAT'
    pos_c    = pos > 0 ? color.lime : pos < 0 ? color.red : color.silver
    arm_txt  = armed > 0 ? 'LONG stop ' + str.tostring(stop_price, format.mintick) : armed < 0 ? 'SHORT stop ' + str.tostring(stop_price, format.mintick) : pending_exit ? 'EXIT next open' : '--'
    f_cell(0, 'TFC Companion', 'close-basis', color.silver)
    f_cell(1, 'TF1 ' + tf1, f_tf_state(y1, o1), color.white)
    f_cell(2, 'TF2 ' + tf2, f_tf_state(y2, o2), color.white)
    f_cell(3, 'TF3 ' + tf3, f_tf_state(y3, o3), color.white)
    f_cell(4, 'TF4 ' + tf4, f_tf_state(y4, o4), color.white)
    f_cell(5, 'TF5 ' + tf5, f_tf_state(y5, o5), color.white)
    f_cell(6, 'TF6 ' + tf6, f_tf_state(y6, o6), color.white)
    f_cell(7, 'EXEC gate', exec_txt, exec_c)
    f_cell(8, 'Regime (' + reg_mode + ')', reg_txt, reg_c)
    f_cell(9, 'Position', pos_txt, pos_c)
    f_cell(10, 'Next bar', arm_txt, color.orange)
    f_cell(11, 'Ratchet L/S', (na(ratchet_long) ? '--' : str.tostring(ratchet_long, format.mintick)) + ' / ' + (na(ratchet_short) ? '--' : str.tostring(ratchet_short, format.mintick)), color.teal)

// ----------------------------------- Alerts -----------------------------------
// Entry fills are intrabar-real: create these with "Once Per Bar".
alertcondition(fill_long,  'TFC long entry fill',  'TFC Companion: LONG entry filled (strategy enters here)')
alertcondition(fill_short, 'TFC short entry fill', 'TFC Companion: SHORT entry filled (strategy enters here)')
// Close-based decisions: create these with "Once Per Bar Close".
alertcondition(pending_exit and pos != 0, 'TFC state-stop', 'TFC Companion: gate lost at close -- strategy exits next open')
alertcondition(armed != 0, 'TFC trigger armed', 'TFC Companion: breakout stop armed for next bar')
