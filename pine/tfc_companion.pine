//@version=6
// =====================================================================================
// TFC Companion [TVB-10]                   v3 -- exit_mode (state | flip) ablation watch
// -------------------------------------------------------------------------------------
// Purpose : MANUAL-TRADING companion to pine/baseline_continuity.pine (pv20 anchor).
//           Shows, live on any chart, exactly what the backtested strategy sees and
//           does: the FTFC exec gate, the regime permits, the armed one-bar breakout
//           trigger, simulated fills/exits, and the governor ratchet levels.
//           NO new detection logic -- the gate/trigger/stop/governor semantics are
//           copied from the deployed strategy (TVB-1 charter reconciliation: FTFC =
//           close vs each enabled TF's CURRENT period open).
// v2      : the strategy logic runs at its OWN timeframe (the 'Strategy TF' input,
//           default 60 = the R1E3 chart TF) while the chart can be any FINER tiling
//           TF (e.g. 5m). Decisions (gate read, state-stop, arming, governor) commit
//           only at Strategy-TF closes, sampled from committed chart bars -- the
//           state machine NEVER repaints or flickers. Fills are checked on every
//           chart bar, so entries appear the moment price trades through the stop
//           (earlier visibility, identical state: a logic bar's high is the max of
//           its chart bars' highs). With chart TF == Strategy TF this is state-
//           identical to v1. NO request.security anywhere: with lookahead_off the
//           HTF value is stale on historical bars (the TVB-3 bug) and the machine's
//           CURRENT state depends on the whole history -- local reconstruction keeps
//           backtest == live by construction.
// Fills   : mirror the strategy's bar model (dump-verified in the tfc/ Python port):
//           exits fill at the logic bar's open; the breakout stop fills at the stop,
//           or at the logic OPEN when the logic bar opens through. An intra-logic-bar
//           gap between chart bars still fills AT the stop -- that is what the
//           Strategy Tester assumes on the logic bar; fidelity is to the backtest.
// Fidelity: the trade SEQUENCE is fee-independent and the governor arms on GROSS
//           profit (TVB-7), so no equity model is needed. slip_ticks (default 1)
//           mirrors the deployed staging only to preserve governor win/loss
//           semantics on scratch trades.
// Alerts  : alertcondition() only (charter S4). Entry fills + exit fills + armed:
//           create with "Once Per Bar" (they are committed, not provisional). The
//           'gate against position' warning is PROVISIONAL until the Strategy-TF
//           close: create with "Once Per Bar Close".
// Warmup  : a gate TF is neutral (grey) until its first period boundary inside
//           loaded history; the first (possibly partial) logic bar matches TV's own
//           partial-period aggregation.
// v3      : exit_mode input mirrors the TVB-10 pre-registered ablation
//           (TFCConfig.exit_mode in the Python engine): 'state' (default,
//           v2-identical) exits when the exec gate loses FULL alignment at the
//           Strategy-TF close; 'flip' exits ONLY on full OPPOSITE alignment and
//           holds through grey. Intended use: TWO instances of this indicator on
//           one chart (one per mode) for live side-by-side observation of the
//           regime-shape mechanism (TVB-10 finding: flip rides bursts, state
//           harvests swings). A 'flip' instance auto-switches marker colors
//           (aqua/purple entries, yellow exit cross) and should be given a
//           different Table position. Alert names are shared between instances
//           (Pine constants) -- include the mode in the alert NAME when creating.
// Defaults: R1E3 two-layer (Strategy TF 60; exec 240/120/60 + regime M/W/D
//           stand_aside), governor OFF. The guard fails LOUDLY on misalignment:
//           chart TF must tile the Strategy TF; the Strategy TF must tile every
//           enabled gate TF.
// =====================================================================================

indicator('TFC Companion [TVB-10]', overlay = true)

// ----------------------------------- Inputs -----------------------------------
var string g_dir = 'Direction'
allow_long  = input.bool(true, 'Allow Long',  group = g_dir)
allow_short = input.bool(true, 'Allow Short', group = g_dir)

var string g_exit = 'Exit rule (TVB-10 ablation -- run two instances to compare live)'
exit_mode = input.string('state', 'Exit mode', options = ['state', 'flip'], group = g_exit, tooltip = 'state: exit when the exec gate loses full alignment at the Strategy-TF close (baseline). flip: exit only on full OPPOSITE alignment; holds through grey (TFO-like cadence).')

var string g_tf = 'Strategy TF + execution gate TFs (FTFC set)'
logic_tf = input.timeframe('60', 'Strategy TF (decisions commit at this TF)', group = g_tf)
y1  = input.bool(true,  '', inline = '1', group = g_tf)
tf1 = input.timeframe('240', 'TF 1', inline = '1', group = g_tf)
y2  = input.bool(true,  '', inline = '2', group = g_tf)
tf2 = input.timeframe('120', 'TF 2', inline = '2', group = g_tf)
y3  = input.bool(true,  '', inline = '3', group = g_tf)
tf3 = input.timeframe('60', 'TF 3', inline = '3', group = g_tf)
y4  = input.bool(false, '', inline = '4', group = g_tf)
tf4 = input.timeframe('M',  'TF 4', inline = '4', group = g_tf)
y5  = input.bool(false, '', inline = '5', group = g_tf)
tf5 = input.timeframe('W',  'TF 5', inline = '5', group = g_tf)
y6  = input.bool(false, '', inline = '6', group = g_tf)
tf6 = input.timeframe('D',  'TF 6', inline = '6', group = g_tf)

var string g_reg = 'Regime layer (charter 3.3) -- M/W/D a-priori, do not tune'
reg_mode = input.string('stand_aside', 'Regime mode', options = ['off', 'stand_aside', 'size_down'], group = g_reg)
rg1  = input.bool(true, '', inline = 'r1', group = g_reg)
rtf1 = input.timeframe('M', 'Regime TF 1', inline = 'r1', group = g_reg)
rg2  = input.bool(true, '', inline = 'r2', group = g_reg)
rtf2 = input.timeframe('W', 'Regime TF 2', inline = 'r2', group = g_reg)
rg3  = input.bool(true, '', inline = 'r3', group = g_reg)
rtf3 = input.timeframe('D', 'Regime TF 3', inline = 'r3', group = g_reg)

var string g_gov = 'Re-entry governor (TVB-6, charter S8) -- zero-parameter ratchet'
gov_mode   = input.string('off', 'Governor mode', options = ['off', 'ratchet'], group = g_gov)
slip_ticks = input.int(1, 'Slippage ticks (governor gross fidelity only)', minval = 0, group = g_gov)

var string g_viz = 'Display'
show_state   = input.bool(true, 'Color bars by gate state (live, chart-close basis)', group = g_viz)
show_levels  = input.bool(true, 'Plot FTFC floor/ceiling (period opens)', group = g_viz)
show_trigger = input.bool(true, 'Plot armed trigger level', group = g_viz)
show_marks   = input.bool(true, 'Plot simulated entry/exit markers', group = g_viz)
show_ratchet = input.bool(true, 'Plot governor ratchet levels', group = g_viz)
show_table   = input.bool(true, 'Show status table', group = g_viz)
table_pos    = input.string('top_right', 'Table position (set differently per instance)', options = ['top_right', 'middle_right', 'bottom_right', 'top_left', 'middle_left', 'bottom_left'], group = g_viz)

// ------------- Guard: chart tiles Strategy TF; Strategy TF tiles every gate TF -------------
// Same day-boundary tiling logic as the strategy's f_guard; misconfigured charts fail
// LOUDLY. chart-tiles-gate follows transitively (chart|logic and logic|gate).
f_guard(simple string base_name, simple int base_s, simple string tf, simple bool enabled) =>
    if enabled
        gs = timeframe.in_seconds(tf)
        if gs < base_s
            runtime.error('TF "' + tf + '" is finer than ' + base_name + '. It must be >= and tiled by it.')
        if gs >= 86400
            if 86400 % base_s != 0
                runtime.error(base_name + ' does not divide 1D -- D/W/M period-open reconstruction would be approximate.')
        else if gs % base_s != 0
            runtime.error('TF "' + tf + '" is not an integer multiple of ' + base_name + ' -- reconstruction would be approximate.')

chart_s = timeframe.in_seconds(timeframe.period)
logic_s = timeframe.in_seconds(logic_tf)
f_guard('the chart TF (' + timeframe.period + ')', chart_s, logic_tf, true)
f_guard('the Strategy TF (' + logic_tf + ')', logic_s, tf1, y1)
f_guard('the Strategy TF (' + logic_tf + ')', logic_s, tf2, y2)
f_guard('the Strategy TF (' + logic_tf + ')', logic_s, tf3, y3)
f_guard('the Strategy TF (' + logic_tf + ')', logic_s, tf4, y4)
f_guard('the Strategy TF (' + logic_tf + ')', logic_s, tf5, y5)
f_guard('the Strategy TF (' + logic_tf + ')', logic_s, tf6, y6)
if reg_mode != 'off'
    f_guard('the Strategy TF (' + logic_tf + ')', logic_s, rtf1, rg1)
    f_guard('the Strategy TF (' + logic_tf + ')', logic_s, rtf2, rg2)
    f_guard('the Strategy TF (' + logic_tf + ')', logic_s, rtf3, rg3)

// ------------- Gate (FTFC): LOCAL period-open reconstruction (TVB-3 fix) -------------
f_open(simple string tf) =>
    ta.valuewhen(timeframe.change(tf), open, 0)

o1 = f_open(tf1)
o2 = f_open(tf2)
o3 = f_open(tf3)
o4 = f_open(tf4)
o5 = f_open(tf5)
o6 = f_open(tf6)

use_arr  = array.from(y1, y2, y3, y4, y5, y6)
open_arr = array.from(o1, o2, o3, o4, o5, o6)

ftfc_up = true
ftfc_dn = true
int n_enabled = 0
float hi_open = na
float lo_open = na
for i = 0 to array.size(use_arr) - 1 by 1
    if array.get(use_arr, i)
        n_enabled += 1
        op = array.get(open_arr, i)
        hi_open := na(hi_open) ? op : math.max(hi_open, op)
        lo_open := na(lo_open) ? op : math.min(lo_open, op)
        if close > op
            ftfc_dn := false
        else if close < op
            ftfc_up := false
        else
            ftfc_up := false
            ftfc_dn := false
if n_enabled == 0
    ftfc_up := false
    ftfc_dn := false

// ------------------------------- Regime layer -------------------------------
f_agg(u_arr, o_arr) =>
    up = true
    dn = true
    int n = 0
    for i = 0 to array.size(u_arr) - 1 by 1
        if array.get(u_arr, i)
            n += 1
            op = array.get(o_arr, i)
            if close > op
                dn := false
            else if close < op
                up := false
            else
                up := false
                dn := false
    if n == 0
        up := false
        dn := false
    [up, dn]

ro1 = f_open(rtf1)
ro2 = f_open(rtf2)
ro3 = f_open(rtf3)
[reg_up, reg_dn] = f_agg(array.from(rg1, rg2, rg3), array.from(ro1, ro2, ro3))
reg_grey = not reg_up and not reg_dn

long_permit  = reg_mode == 'off' ? true : reg_mode == 'stand_aside' ? reg_up : reg_up or reg_grey
short_permit = reg_mode == 'off' ? true : reg_mode == 'stand_aside' ? reg_dn : reg_dn or reg_grey

// --------------------- Position-state machine (strategy replica, logic-TF clocked) ---------------------
// A Strategy-TF ("logic") bar completes when the next one starts (timeframe.change on
// the chart). At that boundary chart bar -- whose open IS the new logic bar's open --
// the machine runs, in strategy order:
//   Phase B for the JUST-COMPLETED logic bar (decided at its close, sampled from the
//   previous chart bar's committed values -- [1] -- so nothing here ever repaints):
//     1) state-stop decision  2) governor alignment reset  3) arm the one-logic-bar
//     breakout stop (flat only, long priority; trigger = completed logic high/low
//     +/- tick).
//   Phase A at the new logic bar's open: a pending exit fills at THIS chart bar's
//   open (win clears the ratchet, loss/scratch ratchets at the failed TRIGGER --
//   arming and exit are mutually exclusive at one boundary, so stop_price still
//   holds the exited trade's trigger).
// Entry fills are then checked on EVERY chart bar while the stop is armed.
// With chart TF == Strategy TF this reduces exactly to the v1 per-bar machine.
slip = slip_ticks * syminfo.mintick
new_logic = timeframe.change(logic_tf)

var int   pos           = 0      // +1 long, -1 short, 0 flat
var float ep            = na     // entry fill price (slippage-adjusted)
var bool  pending_exit  = false
var int   armed         = 0      // stop armed for the CURRENT logic bar: +1 / -1 / 0
var float stop_price    = na     // the armed trigger level
var float ratchet_long  = na
var float ratchet_short = na
var float l_high        = na     // developing logic bar extremes
var float l_low         = na

bool fill_long  = false
bool fill_short = false
bool exit_fill  = false
bool just_armed = false

if new_logic
    // completed logic bar N (running vars still hold period-N values)
    lb_high = l_high
    lb_low  = l_low
    // gate/permits at logic-N close = previous chart bar's committed state
    up_c = ftfc_up[1]
    dn_c = ftfc_dn[1]
    lp_c = long_permit[1]
    sp_c = short_permit[1]
    // ---- Phase B for logic bar N (pre-fill state) ----
    // exit_mode 'state': first loss of full alignment. 'flip' (TVB-10): only
    // full OPPOSITE alignment; holds through grey. Mirrors tfc/simulator.py.
    if exit_mode == 'flip'
        if pos > 0 and dn_c
            pending_exit := true
        if pos < 0 and up_c
            pending_exit := true
    else
        if pos > 0 and not up_c
            pending_exit := true
        if pos < 0 and not dn_c
            pending_exit := true
    if dn_c
        ratchet_long := na
    if up_c
        ratchet_short := na
    armed := 0  // the one-logic-bar stop expires unfilled
    gov = gov_mode == 'ratchet'
    gl_ok = not gov or na(ratchet_long)  or lb_high + syminfo.mintick > ratchet_long
    gs_ok = not gov or na(ratchet_short) or lb_low - syminfo.mintick < ratchet_short
    if pos == 0 and not pending_exit and not na(lb_high)
        if allow_long and up_c and lp_c and gl_ok
            armed := 1
            stop_price := lb_high + syminfo.mintick
            just_armed := true
        else if allow_short and dn_c and sp_c and gs_ok
            armed := -1
            stop_price := lb_low - syminfo.mintick
            just_armed := true
    // ---- Phase A: pending exit fills at the new logic bar's open (= this open) ----
    if pending_exit and pos != 0
        xp = pos > 0 ? open - slip : open + slip
        gross_win = pos > 0 ? xp > ep : xp < ep
        if pos > 0
            ratchet_long := gross_win ? na : stop_price
        else
            ratchet_short := gross_win ? na : stop_price
        exit_fill := true
        pos := 0
        pending_exit := false
    // reset running extremes for the new logic bar
    l_high := high
    l_low  := low
else
    l_high := na(l_high) ? high : math.max(l_high, high)
    l_low  := na(l_low)  ? low  : math.min(l_low, low)

// ---- Phase A: entry fills, checked every chart bar while armed ----
// Gap-through applies only to the LOGIC bar's open (the boundary bar); a later
// chart bar crossing the stop fills AT the stop, as the Strategy Tester assumes
// on the logic bar (fidelity to the backtest's bar model).
if armed > 0 and pos == 0
    if new_logic and open > stop_price
        ep := open + slip
        fill_long := true
    else if high >= stop_price
        ep := stop_price + slip
        fill_long := true
    if fill_long
        pos := 1
        armed := 0
else if armed < 0 and pos == 0
    if new_logic and open < stop_price
        ep := open - slip
        fill_short := true
    else if low <= stop_price
        ep := stop_price - slip
        fill_short := true
    if fill_short
        pos := -1
        armed := 0

// live (provisional) warning: the EXIT CONDITION for the current mode is true on
// this chart bar; commits only at the Strategy-TF close
gate_against_pos = exit_mode == 'flip' ? (pos > 0 and ftfc_dn) or (pos < 0 and ftfc_up) : (pos > 0 and not ftfc_up) or (pos < 0 and not ftfc_dn)

// ----------------------------------- Visualization -----------------------------------
state_col = ftfc_up ? color.new(color.green, 55) : ftfc_dn ? color.new(color.red, 55) : color.new(color.gray, 70)
barcolor(show_state ? state_col : na)
reg_col = reg_mode == 'off' ? na : reg_up ? color.new(color.green, 92) : reg_dn ? color.new(color.red, 92) : color.new(color.gray, 92)
bgcolor(reg_col)

plot(show_levels ? hi_open : na, 'FTFC up floor (max open)',   color = color.new(color.green, 40), style = plot.style_stepline)
plot(show_levels ? lo_open : na, 'FTFC dn ceiling (min open)', color = color.new(color.red, 40),   style = plot.style_stepline)

plot(show_trigger and armed != 0 ? stop_price : na, 'Armed trigger (this logic bar)', color = color.new(color.orange, 0), style = plot.style_circles, linewidth = 2)
plot(show_trigger and pos != 0 ? ep : na, 'Entry fill', color = color.new(color.blue, 30), style = plot.style_linebr)

// flip-mode instances auto-switch marker colors so two overlaid instances stay readable
col_long  = exit_mode == 'flip' ? color.new(color.aqua, 0)   : color.new(color.green, 0)
col_short = exit_mode == 'flip' ? color.new(color.purple, 0) : color.new(color.red, 0)
col_exit  = exit_mode == 'flip' ? color.new(color.yellow, 0) : color.new(color.gray, 0)
plotshape(show_marks and fill_long,  'Sim long entry',  shape.triangleup,   location.belowbar, col_long,  size = size.small)
plotshape(show_marks and fill_short, 'Sim short entry', shape.triangledown, location.abovebar, col_short, size = size.small)
plotshape(show_marks and exit_fill,  'Sim exit (fill @ logic open)', shape.xcross, location.abovebar, col_exit, size = size.tiny)

plot(show_ratchet and gov_mode == 'ratchet' ? ratchet_long : na,  'Governor ratchet (long)',  color = color.new(color.teal, 20),   style = plot.style_linebr)
plot(show_ratchet and gov_mode == 'ratchet' ? ratchet_short : na, 'Governor ratchet (short)', color = color.new(color.maroon, 20), style = plot.style_linebr)

// ----------------------------------- Status table -----------------------------------
f_tf_state(simple bool en, float op) =>
    not en ? '--' : na(op) ? 'warmup' : close > op ? 'UP' : close < op ? 'DOWN' : 'flat'

f_tpos(simple string s) =>
    s == 'top_right' ? position.top_right : s == 'middle_right' ? position.middle_right : s == 'bottom_right' ? position.bottom_right : s == 'top_left' ? position.top_left : s == 'middle_left' ? position.middle_left : position.bottom_left

var table t = table.new(f_tpos(table_pos), 2, 13, bgcolor = color.new(color.black, 20), border_width = 1, border_color = color.new(color.gray, 60))
f_cell(int r, string k, string v, color c) =>
    table.cell(t, 0, r, k, text_color = color.white, text_size = size.small, text_halign = text.align_left)
    table.cell(t, 1, r, v, text_color = c, text_size = size.small)

if show_table and barstate.islast
    exec_txt = ftfc_up ? 'ALIGNED UP' : ftfc_dn ? 'ALIGNED DOWN' : 'GREY'
    exec_c   = ftfc_up ? color.lime : ftfc_dn ? color.red : color.gray
    reg_txt  = reg_mode == 'off' ? 'off' : reg_up ? 'UP' : reg_dn ? 'DOWN' : 'GREY'
    reg_c    = reg_mode == 'off' ? color.gray : reg_up ? color.lime : reg_dn ? color.red : color.gray
    pos_txt  = pos > 0 ? 'LONG @ ' + str.tostring(ep, format.mintick) : pos < 0 ? 'SHORT @ ' + str.tostring(ep, format.mintick) : 'FLAT'
    pos_txt := pos != 0 and gate_against_pos ? pos_txt + ' (gate against, prov.)' : pos_txt
    pos_c    = pos > 0 ? color.lime : pos < 0 ? color.red : color.silver
    arm_txt  = armed > 0 ? 'LONG stop ' + str.tostring(stop_price, format.mintick) : armed < 0 ? 'SHORT stop ' + str.tostring(stop_price, format.mintick) : '--'
    f_cell(0, 'TFC Companion v3', exit_mode + ' exit / close-basis', exit_mode == 'flip' ? color.aqua : color.silver)
    f_cell(1, 'Strategy TF', logic_tf, color.orange)
    f_cell(2, 'TF1 ' + tf1, f_tf_state(y1, o1), color.white)
    f_cell(3, 'TF2 ' + tf2, f_tf_state(y2, o2), color.white)
    f_cell(4, 'TF3 ' + tf3, f_tf_state(y3, o3), color.white)
    f_cell(5, 'TF4 ' + tf4, f_tf_state(y4, o4), color.white)
    f_cell(6, 'TF5 ' + tf5, f_tf_state(y5, o5), color.white)
    f_cell(7, 'TF6 ' + tf6, f_tf_state(y6, o6), color.white)
    f_cell(8, 'EXEC gate (live)', exec_txt, exec_c)
    f_cell(9, 'Regime (' + reg_mode + ')', reg_txt, reg_c)
    f_cell(10, 'Position', pos_txt, pos_c)
    f_cell(11, 'Working stop', arm_txt, color.orange)
    f_cell(12, 'Ratchet L/S', (na(ratchet_long) ? '--' : str.tostring(ratchet_long, format.mintick)) + ' / ' + (na(ratchet_short) ? '--' : str.tostring(ratchet_short, format.mintick)), color.teal)

// ----------------------------------- Alerts -----------------------------------
// Committed events -- create with "Once Per Bar" (they fire the moment they happen
// and never repaint):
alertcondition(fill_long,  'TFC long entry fill',  'TFC Companion: LONG entry filled (strategy enters here)')
alertcondition(fill_short, 'TFC short entry fill', 'TFC Companion: SHORT entry filled (strategy enters here)')
alertcondition(exit_fill,  'TFC exit fill',        'TFC Companion: exit condition met at the Strategy-TF close -- strategy exited at this open')
alertcondition(just_armed, 'TFC trigger armed',    'TFC Companion: breakout stop armed for this Strategy-TF bar')
// Provisional (commits only at the Strategy-TF close) -- create with "Once Per Bar Close":
alertcondition(gate_against_pos, 'TFC exit condition live (provisional)', 'TFC Companion: the active exit condition is currently true -- exit fires if it holds to the Strategy-TF close')
