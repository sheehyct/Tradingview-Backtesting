# ============================================
# SECURITY CRITICAL - NEVER COMMIT
# ============================================
.env
.env.*
!.env.template
*.key
*.secret
credentials.json
secrets.json
# Claude Code LOCAL settings may hold secrets/paths -- keep local.
.claude/settings.local.json

# ============================================
# DATA / BACKTEST EXPORTS - large or regenerable
# ============================================
# Strategy Tester CSV exports + reference candle pulls are large/regenerable.
# Small JSON sweep SUMMARIES are intentionally tracked (results/*.json kept).
*.csv
*.parquet
*.h5
*.db
*.sqlite
data/
market_data/
validation/screenshots/*.png

# Logs / temp
logs/
*.log
tmp/
temp/
temporary/
*.tmp

# ============================================
# INTENTIONALLY TRACKED (note vs vbt-workspace)
# ============================================
# .mcp.json is TRACKED here on purpose: the tradingview + openmemory blocks
# contain NO secrets, so committing makes the MCP wiring reproducible on clone.
# (This fixes the vbt-workspace gotcha where gitignored .mcp.json did not travel.)
